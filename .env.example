# Copy this file to .env and fill in your values.
# The .env file is gitignored — never commit it.

# Palladiumd RPC credentials (must match palladium-stack/.palladium/palladium.conf)
PALLADIUM_RPCUSER=your_rpc_user
PALLADIUM_RPCPASSWORD=your_rpc_password

# Optional: announce a domain name instead of (or in addition to) the auto-discovered IP.
# The node auto-discovers its public IP via --announce-addr-discovered=true.
# Set this only if you have a DNS name pointing to this node.
# Example: ANNOUNCE_DOMAIN=ln.yourdomain.com
ANNOUNCE_DOMAIN=
